# ============================================================
# VARIÁVEIS DE AMBIENTE — Desenrole.ai
# ============================================================
# Copie para `.env.local` (ignorado pelo git) e preencha.
#
# NUNCA misturar ambientes: cada um tem seu próprio projeto Supabase.
#   local        → supabase start (Docker) → http://127.0.0.1:54321
#   development  → projeto "desenrole-gringa-dev"
#   production   → projeto separado, criado só no lançamento
#
# NUNCA usar credenciais de produção em desenvolvimento.
# ============================================================

# URL pública da aplicação. Usada para montar os links dos e-mails
# de confirmação e recuperação de senha.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# Supabase — obrigatórias
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# Supabase — service role
# ------------------------------------------------------------
# Necessária a partir da fase Stripe S3 (webhook/sync): escreve nas
# tabelas financeiras, graváveis apenas por service_role. Usada SÓ no
# módulo server-only de sincronização. NUNCA em NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Stripe (test mode em dev; live só em produção)
# ------------------------------------------------------------
# Secretas — SÓ no servidor, nunca NEXT_PUBLIC_*.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# ID do Stripe Price do plano Premium mensal (US$ 9,90/mês).
# Criado no Stripe (Dashboard/API) e espelhado em plan_prices.
STRIPE_MONTHLY_PRICE_ID=
# Pública — usada no cliente (redirect ao Checkout hospedado).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
