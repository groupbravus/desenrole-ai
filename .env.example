# ============================================================
# VARIÁVEIS DE AMBIENTE — Desenrole.ai
# ============================================================
# Copie para `.env.local` (ignorado pelo git) e preencha.
#
# NUNCA misturar ambientes: cada um tem seu próprio projeto Supabase.
#   local        → supabase start (Docker) → http://127.0.0.1:54321
#   development  → projeto "desenrole-gringa-dev"
#   production   → projeto separado, criado só no lançamento
#
# NUNCA usar credenciais de produção em desenvolvimento.
# ============================================================

# URL pública da aplicação. Usada para montar os links dos e-mails
# (confirmação/recuperação) e as URLs de retorno do Checkout.
#   local dev  → http://localhost:3000
#   preview    → https://desenrole-ai-jq8i.vercel.app
#   production → o domínio final
# EM PRODUÇÃO (Vercel), defina esta variável no ambiente do projeto com a
# URL pública HTTPS — nunca localhost. Sem ela, o servidor cai no host da
# request (na Vercel já é o domínio correto), mas defini-la é o esperado.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Quiz EXTERNO — porta de entrada do CTA "Começar" na home.
# Sem esta variável, o botão fica desabilitado (mensagem segura), a home
# não quebra. Nunca use localhost aqui; nunca aponte para o quiz interno.
# Na Vercel, configurar depois com o link definitivo.
NEXT_PUBLIC_EXTERNAL_QUIZ_URL=

# ------------------------------------------------------------
# Supabase — obrigatórias
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# Supabase — service role
# ------------------------------------------------------------
# Necessária a partir da fase Stripe S3 (webhook/sync): escreve nas
# tabelas financeiras, graváveis apenas por service_role. Usada SÓ no
# módulo server-only de sincronização. NUNCA em NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Stripe (test mode em dev; live só em produção)
# ------------------------------------------------------------
# Secretas — SÓ no servidor, nunca NEXT_PUBLIC_*.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# ID do Stripe Price do plano Premium mensal (US$ 9,90/mês).
# Criado no Stripe (Dashboard/API) e espelhado em plan_prices.
STRIPE_MONTHLY_PRICE_ID=
# Pública — usada no cliente (redirect ao Checkout hospedado).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------------------------------------
# OpenAI — análise real de conversa (GPT-4.1, visão + JSON estruturado)
# ------------------------------------------------------------
# Secreta — SÓ no servidor, nunca NEXT_PUBLIC_*. Usada em
# src/lib/ai/analyze-conversation.ts. Sem ela, a análise falha com
# "unknown" (ver getOpenAI() em src/lib/ai/openai.ts).
OPENAI_API_KEY=
